--- a/chrome/browser/ui/color/chrome_color_mixer.cc
+++ b/chrome/browser/ui/color/chrome_color_mixer.cc
@@ -0,0 +0,14 @@ void AddChromeColorMixer(ui::ColorProvid
+  // Zephyr sidebar surface colors.
+  // Sidebar is 88% frame color + 12% neutral reference for a subtle warm lift.
+  mixer[kColorZephyrSidebarSurface] = dark_mode
+      ? AlphaBlend({ui::kColorFrameActive}, {kColorRefNeutral17}, 0xE0)
+      : AlphaBlend({ui::kColorFrameActive}, {kColorRefNeutral96}, 0xE0);
+  mixer[kColorZephyrSidebarSurfaceInactive] = dark_mode
+      ? AlphaBlend({ui::kColorFrameInactive}, {kColorRefNeutral17}, 0xE0)
+      : AlphaBlend({ui::kColorFrameInactive}, {kColorRefNeutral96}, 0xE0);
+  // Hover/selected states: white overlay on sidebar surface.
+  mixer[kColorZephyrSidebarTabHover] =
+      AlphaBlend({SK_ColorWHITE}, {kColorZephyrSidebarSurface}, 0x14);
+  mixer[kColorZephyrSidebarTabSelected] =
+      AlphaBlend({SK_ColorWHITE}, {kColorZephyrSidebarSurface}, 0x26);
+
