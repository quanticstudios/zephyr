--- a/chrome/browser/ui/color/chrome_color_mixer.cc
+++ b/chrome/browser/ui/color/chrome_color_mixer.cc
@@ -0,0 +0,31 @@ void AddChromeColorMixer(ui::ColorProvid
+  // Zephyr sidebar surface colors.
+  // Sidebar is 88% frame color + 12% neutral reference for a subtle warm lift.
+  mixer[kColorZephyrSidebarSurface] = dark_mode
+      ? AlphaBlend({ui::kColorFrameActive}, {kColorRefNeutral17}, 0xE0)
+      : AlphaBlend({ui::kColorFrameActive}, {kColorRefNeutral96}, 0xE0);
+  mixer[kColorZephyrSidebarSurfaceInactive] = dark_mode
+      ? AlphaBlend({ui::kColorFrameInactive}, {kColorRefNeutral17}, 0xE0)
+      : AlphaBlend({ui::kColorFrameInactive}, {kColorRefNeutral96}, 0xE0);
+  // Hover/selected states: white overlay on sidebar surface.
+  mixer[kColorZephyrSidebarTabHover] =
+      AlphaBlend({SK_ColorWHITE}, {kColorZephyrSidebarSurface}, 0x14);
+  mixer[kColorZephyrSidebarTabSelected] =
+      AlphaBlend({SK_ColorWHITE}, {kColorZephyrSidebarSurface}, 0x26);
+
+  // Zephyr folder visual colors.
+  // Folder header: 5% white lift over sidebar surface.
+  mixer[kColorZephyrFolderHeaderBg] =
+      AlphaBlend({SK_ColorWHITE}, {kColorZephyrSidebarSurface}, 0x0C);
+  mixer[kColorZephyrFolderHeaderBgHover] =
+      AlphaBlend({SK_ColorWHITE}, {kColorZephyrSidebarSurface}, 0x1A);
+  // Folder container: subtle inset (3% black overlay).
+  mixer[kColorZephyrFolderContainerBg] =
+      AlphaBlend({SK_ColorBLACK}, {kColorZephyrSidebarSurface}, 0x08);
+  // Fallback group line color (views use per-group theme color normally).
+  mixer[kColorZephyrFolderGroupLine] = {kColorRefPrimary60};
+  // Drop indicator: accent pill.
+  mixer[kColorZephyrFolderDropIndicator] = {kColorRefPrimary60};
+  // Drop highlight: translucent overlay for "inside folder" state.
+  mixer[kColorZephyrFolderDropHighlight] =
+      AlphaBlend({kColorRefPrimary60}, {kColorZephyrSidebarSurface}, 0x30);
+
