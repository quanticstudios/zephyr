 void TabSearchPageHandler::ExecuteLauncherCommand(
     int32_t command_id,
     ExecuteLauncherCommandCallback callback) {
-  const bool executed = browser_ && IsSupportedLauncherCommand(command_id) &&
+  if (!browser_) {
+    std::move(callback).Run(false);
+    return;
+  }
+
+  auto synthetic_it = zephyr_launcher_commands_.find(command_id);
+  if (synthetic_it != zephyr_launcher_commands_.end()) {
+    auto* folder_controller =
+        browser_->GetFeatures().zephyr_folder_window_controller();
+    if (!folder_controller) {
+      std::move(callback).Run(false);
+      return;
+    }
+
+    const int context_index =
+        GetSelectionContextIndex(browser_->tab_strip_model());
+    if (context_index == TabStripModel::kNoTab) {
+      std::move(callback).Run(false);
+      return;
+    }
+
+    const ZephyrLauncherCommandPayload& payload = synthetic_it->second;
+    bool executed = false;
+    switch (payload.action) {
+      case ZephyrLauncherCommandPayload::Action::kCreateFolderFromSelection:
+        folder_controller->CreateFolderFromSelection(context_index);
+        executed = true;
+        break;
+      case ZephyrLauncherCommandPayload::Action::kMoveSelectionToFolder:
+        executed = folder_controller->MoveSelectionToFolder(context_index,
+                                                            payload.folder_id);
+        break;
+      case ZephyrLauncherCommandPayload::Action::kToggleFolderCollapsed:
+        executed = folder_controller->ToggleFolderCollapsed(payload.folder_id);
+        break;
+      case ZephyrLauncherCommandPayload::Action::kRenameFolder: {
+        std::optional<tabs::ZephyrFolderModel::Folder> folder =
+            folder_controller->folder_model()->GetFolderById(payload.folder_id);
+        if (!folder.has_value()) {
+          executed = false;
+          break;
+        }
+        std::u16string new_title = folder->title;
+        new_title += u" Renamed";
+        executed = folder_controller->RenameFolder(payload.folder_id, new_title);
+        break;
+      }
+    }
+    std::move(callback).Run(executed);
+    return;
+  }
+
+  const bool executed = IsSupportedLauncherCommand(command_id) &&
                         chrome::SupportsCommand(browser_, command_id) &&
                         chrome::ExecuteCommand(browser_, command_id);
   std::move(callback).Run(executed);
