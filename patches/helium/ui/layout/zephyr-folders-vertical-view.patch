+tabs::ZephyrFolderWindowController*
+VerticalUnpinnedTabContainerView::GetFolderController() const {
+  const auto* controller = collection_node_ ? collection_node_->GetController()
+                                            : nullptr;
+  if (!controller) {
+    return nullptr;
+  }
+  BrowserView* browser_view = controller->browser_view();
+  if (!browser_view) {
+    return nullptr;
+  }
+  return browser_view->browser()->GetFeatures().zephyr_folder_window_controller();
+}
+
+void VerticalUnpinnedTabContainerView::MaybeObserveFolderModel() {
+  if (folder_model_subscription_) {
+    return;
+  }
+  auto* folder_controller = GetFolderController();
+  if (!folder_controller) {
+    return;
+  }
+  folder_model_subscription_ = folder_controller->folder_model()->RegisterOnChanged(
+      base::BindRepeating(&VerticalUnpinnedTabContainerView::OnFoldersChanged,
+                          base::Unretained(this)));
+}
+
+void VerticalUnpinnedTabContainerView::OnFoldersChanged() {
+  SyncFolderHeaders();
+  InvalidateLayout();
+}
+
+void VerticalUnpinnedTabContainerView::SyncFolderHeaders() {
+  MaybeObserveFolderModel();
+
+  tabs::ZephyrFolderWindowController* folder_controller = GetFolderController();
+  if (!folder_controller) {
+    for (auto& [_, header] : folder_headers_) {
+      RemoveChildViewT(header.get());
+    }
+    folder_headers_.clear();
+    return;
+  }
+
+  const std::vector<tabs::ZephyrFolderModel::Folder> folders =
+      folder_controller->GetFolders();
+  std::set<std::string> active_ids;
+  for (const auto& folder : folders) {
+    active_ids.insert(folder.id);
+  }
+
+  for (auto it = folder_headers_.begin(); it != folder_headers_.end();) {
+    if (active_ids.contains(it->first)) {
+      ++it;
+      continue;
+    }
+    RemoveChildViewT(it->second.get());
+    it = folder_headers_.erase(it);
+  }
+
+  for (const auto& folder : folders) {
+    ZephyrFolderHeaderView* header = nullptr;
+    auto it = folder_headers_.find(folder.id);
+    if (it == folder_headers_.end()) {
+      header = AddChildView(std::make_unique<ZephyrFolderHeaderView>(
+          folder.id, base::BindRepeating(
+                         &VerticalUnpinnedTabContainerView::ToggleFolderCollapsed,
+                         base::Unretained(this))));
+      folder_headers_[folder.id] = header;
+    } else {
+      header = it->second.get();
+    }
+    header->SetVisible(true);
+    header->Update(folder.title, folder.collapsed);
+  }
+}
+
+std::optional<std::string> VerticalUnpinnedTabContainerView::GetFolderForView(
+    const views::View* view) const {
+  auto* tab_view = views::AsViewClass<const VerticalTabView>(view);
+  if (!tab_view) {
+    return std::nullopt;
+  }
+
+  const TabCollectionNode* node = tab_view->collection_node();
+  if (!node || !std::holds_alternative<const tabs::TabInterface*>(node->GetNodeData())) {
+    return std::nullopt;
+  }
+
+  const tabs::TabInterface* tab =
+      std::get<const tabs::TabInterface*>(node->GetNodeData());
+  const std::optional<int32_t> session_id = tabs::GetSessionIdForTab(tab);
+  if (!session_id.has_value()) {
+    return std::nullopt;
+  }
+
+  tabs::ZephyrFolderWindowController* folder_controller = GetFolderController();
+  if (!folder_controller) {
+    return std::nullopt;
+  }
+  return folder_controller->folder_model()->GetFolderForSessionId(*session_id);
+}
+
+void VerticalUnpinnedTabContainerView::ToggleFolderCollapsed(
+    const std::string& folder_id) {
+  tabs::ZephyrFolderWindowController* folder_controller = GetFolderController();
+  if (!folder_controller) {
+    return;
+  }
+  folder_controller->ToggleFolderCollapsed(folder_id);
+}
+
+void VerticalUnpinnedTabContainerView::MoveDraggedSelectionToFolder(
+    const std::string& folder_id) {
+  tabs::ZephyrFolderWindowController* folder_controller = GetFolderController();
+  if (!folder_controller) {
+    return;
+  }
+  const int context_index = GetDragHandler().GetDragContextIndex();
+  if (context_index == TabStripModel::kNoTab) {
+    return;
+  }
+  folder_controller->MoveSelectionToFolder(context_index, folder_id);
+}
+
+void VerticalUnpinnedTabContainerView::RemoveDraggedSelectionFromFolder() {
+  tabs::ZephyrFolderWindowController* folder_controller = GetFolderController();
+  if (!folder_controller) {
+    return;
+  }
+  const int context_index = GetDragHandler().GetDragContextIndex();
+  if (context_index == TabStripModel::kNoTab) {
+    return;
+  }
+  folder_controller->RemoveSelectionFromFolder(context_index);
+}
