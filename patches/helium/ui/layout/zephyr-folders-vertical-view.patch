+  collapsed_ = collapsed;
+  SetText((collapsed_ ? u"> " : u"v ") + title);
+}
+
+void ZephyrFolderHeaderView::OnPressed(const ui::Event& event) {
+  if (toggle_callback_) {
+    toggle_callback_.Run(folder_id_);
+  }
+}
