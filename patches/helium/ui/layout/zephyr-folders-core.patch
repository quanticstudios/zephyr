+#include "chrome/browser/ui/browser_window/public/browser_window_interface.h"
+#include "chrome/browser/ui/tabs/tab_strip_model.h"
+#include "components/tabs/public/tab_interface.h"
+#include "ui/base/models/list_selection_model.h"
+
+namespace tabs {
+
+ZephyrFolderWindowController::ZephyrFolderWindowController(
+    BrowserWindowInterface* browser_window,
+    PrefService* pref_service,
+    TabStripModel* tab_strip_model)
+    : browser_window_(browser_window),
+      tab_strip_model_(tab_strip_model),
+      folder_model_(pref_service) {
+  CHECK(browser_window_);
+  CHECK(tab_strip_model_);
+
+  tab_strip_model_->AddObserver(this);
+  folder_model_.MaybeRunNativeGroupMigration(tab_strip_model_);
+  folder_model_.CleanupAssignments(CollectActiveSessionIds());
+}
+
+ZephyrFolderWindowController::~ZephyrFolderWindowController() {
+  tab_strip_model_->RemoveObserver(this);
+}
+
+std::vector<ZephyrFolderModel::Folder>
+ZephyrFolderWindowController::GetFolders() const {
+  return folder_model_.GetFolders();
+}
+
+std::optional<std::string> ZephyrFolderWindowController::GetFolderForTab(
+    const TabInterface* tab) const {
+  std::optional<int32_t> session_id = GetSessionIdForTab(tab);
+  if (!session_id.has_value()) {
+    return std::nullopt;
+  }
+  return folder_model_.GetFolderForSessionId(*session_id);
+}
+
+std::string ZephyrFolderWindowController::CreateFolderFromSelection(
+    int context_index,
+    const std::u16string& title) {
+  const std::u16string resolved_title =
+      title.empty() ? BuildDefaultFolderTitle() : title;
+  const std::string folder_id = folder_model_.CreateFolder(resolved_title);
+  MoveSelectionToFolder(context_index, folder_id);
+  return folder_id;
+}
+
+bool ZephyrFolderWindowController::MoveSelectionToFolder(
+    int context_index,
+    const std::string& folder_id) {
+  bool changed = false;
+  for (int32_t session_id : GetSessionIdsForSelection(context_index)) {
+    changed = folder_model_.AssignSessionToFolder(session_id, folder_id) ||
+              changed;
+  }
+  return changed;
+}
+
+bool ZephyrFolderWindowController::RemoveSelectionFromFolder(int context_index) {
+  bool changed = false;
+  for (int32_t session_id : GetSessionIdsForSelection(context_index)) {
+    changed = folder_model_.UnassignSession(session_id) || changed;
+  }
+  return changed;
+}
+
+bool ZephyrFolderWindowController::ToggleFolderCollapsed(
+    const std::string& folder_id) {
+  std::optional<ZephyrFolderModel::Folder> folder =
+      folder_model_.GetFolderById(folder_id);
+  if (!folder.has_value()) {
+    return false;
+  }
+  return folder_model_.SetFolderCollapsed(folder_id, !folder->collapsed);
+}
+
+bool ZephyrFolderWindowController::RenameFolder(const std::string& folder_id,
+                                                const std::u16string& title) {
+  return folder_model_.RenameFolder(folder_id, title);
+}
+
+std::vector<int32_t> ZephyrFolderWindowController::GetSessionIdsForSelection(
+    int context_index) const {
+  std::vector<int32_t> ids;
+  for (TabInterface* tab : GetTabsForSelection(context_index)) {
+    std::optional<int32_t> session_id = GetSessionIdForTab(tab);
+    if (session_id.has_value()) {
+      ids.push_back(*session_id);
+    }
+  }
+  return ids;
+}
+
+void ZephyrFolderWindowController::OnTabStripModelChanged(
+    TabStripModel* tab_strip_model,
+    const TabStripModelChange& change,
+    const TabStripSelectionChange& selection) {
+  folder_model_.CleanupAssignments(CollectActiveSessionIds());
+}
+
+void ZephyrFolderWindowController::OnTabPinnedStateChanged(TabInterface* tab,
+                                                           int model_index) {
+  folder_model_.CleanupAssignments(CollectActiveSessionIds());
+}
+
+void ZephyrFolderWindowController::OnTabGroupChanged(
+    const TabGroupChange& change) {
+  folder_model_.CleanupAssignments(CollectActiveSessionIds());
+}
+
+std::vector<TabInterface*> ZephyrFolderWindowController::GetTabsForSelection(
+    int context_index) const {
+  std::vector<int> indices;
+  if (tab_strip_model_->ContainsIndex(context_index) &&
+      tab_strip_model_->IsTabSelected(context_index)) {
+    const ui::ListSelectionModel::SelectedIndices selected_indices =
+        tab_strip_model_->selection_model()
+            .GetListSelectionModel()
+            .selected_indices();
+    indices = std::vector<int>(selected_indices.begin(), selected_indices.end());
+  } else if (tab_strip_model_->ContainsIndex(context_index)) {
+    indices = {context_index};
+  } else if (tab_strip_model_->active_index() != TabStripModel::kNoTab) {
+    indices = {tab_strip_model_->active_index()};
+  }
+
+  std::vector<TabInterface*> tabs;
+  tabs.reserve(indices.size());
+  for (int index : indices) {
+    if (!tab_strip_model_->ContainsIndex(index)) {
+      continue;
+    }
+    tabs.push_back(tab_strip_model_->GetTabAtIndex(index));
+  }
+  return tabs;
+}
+
+std::set<int32_t> ZephyrFolderWindowController::CollectActiveSessionIds() const {
+  std::set<int32_t> session_ids;
+  for (int index = 0; index < tab_strip_model_->count(); ++index) {
+    std::optional<int32_t> session_id =
+        GetSessionIdForTab(tab_strip_model_->GetTabAtIndex(index));
+    if (session_id.has_value()) {
+      session_ids.insert(*session_id);
+    }
+  }
+  return session_ids;
+}
+
+std::u16string ZephyrFolderWindowController::BuildDefaultFolderTitle() const {
+  const int index = static_cast<int>(folder_model_.GetFolders().size()) + 1;
+  return GetZephyrDefaultFolderTitle(index);
+}
+
+}  // namespace tabs
