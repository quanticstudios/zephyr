+namespace tabs {
+namespace {
+
+constexpr char kStateNextFolderId[] = "next_folder_id";
+constexpr char kStateFolders[] = "folders";
+constexpr char kStateOrder[] = "order";
+constexpr char kStateAssignments[] = "assignments";
+
+constexpr char kFolderTitle[] = "title";
+constexpr char kFolderCollapsed[] = "collapsed";
+constexpr char kFolderIcon[] = "icon";
+constexpr char kFolderTheme[] = "theme";
+
+std::string SessionKey(int32_t session_id) {
+  return base::NumberToString(session_id);
+}
+
+std::u16string GetMigrationTitle(const std::u16string& group_title,
+                                 int fallback_index) {
+  if (!group_title.empty()) {
+    return group_title;
+  }
+  return GetZephyrDefaultFolderTitle(fallback_index);
+}
+
+}  // namespace
+
+ZephyrFolderModel::ZephyrFolderModel(PrefService* pref_service)
+    : pref_service_(pref_service) {
+  CHECK(pref_service_);
+  EnsureStateShape();
+}
+
+ZephyrFolderModel::~ZephyrFolderModel() = default;
+
+base::CallbackListSubscription ZephyrFolderModel::RegisterOnChanged(
+    base::RepeatingClosure callback) {
+  return on_changed_callback_list_.Add(std::move(callback));
+}
+
+int ZephyrFolderModel::GetSchemaVersion() const {
+  return pref_service_->GetInteger(prefs::kZephyrFoldersSchemaVersion);
+}
+
+std::vector<ZephyrFolderModel::Folder> ZephyrFolderModel::GetFolders() const {
+  std::vector<Folder> folders;
+  const base::Value::Dict& state =
+      pref_service_->GetDict(prefs::kZephyrFoldersState);
+  const base::Value::Dict* folders_dict = state.FindDict(kStateFolders);
+  const base::Value::List* order = state.FindList(kStateOrder);
+  if (!folders_dict || !order) {
+    return folders;
+  }
+
+  folders.reserve(order->size());
+  for (const base::Value& value : *order) {
+    const std::string* folder_id = value.GetIfString();
+    if (!folder_id) {
+      continue;
+    }
+    const base::Value::Dict* folder_dict = folders_dict->FindDict(*folder_id);
+    if (!folder_dict) {
+      continue;
+    }
+
+    Folder folder;
+    folder.id = *folder_id;
+    folder.title = base::UTF8ToUTF16(
+        folder_dict->FindString(kFolderTitle)
+            ? *folder_dict->FindString(kFolderTitle)
+            : "Folder");
+    folder.collapsed = folder_dict->FindBool(kFolderCollapsed).value_or(false);
+    folder.icon = folder_dict->FindString(kFolderIcon)
+                      ? *folder_dict->FindString(kFolderIcon)
+                      : "folder";
+    folder.theme = folder_dict->FindString(kFolderTheme)
+                       ? *folder_dict->FindString(kFolderTheme)
+                       : "default";
+    folders.push_back(std::move(folder));
+  }
+
+  return folders;
+}
+
+std::optional<ZephyrFolderModel::Folder> ZephyrFolderModel::GetFolderById(
+    const std::string& folder_id) const {
+  for (const Folder& folder : GetFolders()) {
+    if (folder.id == folder_id) {
+      return folder;
+    }
+  }
+  return std::nullopt;
+}
+
+std::optional<std::string> ZephyrFolderModel::GetFolderForSessionId(
+    int32_t session_id) const {
+  const base::Value::Dict& state =
+      pref_service_->GetDict(prefs::kZephyrFoldersState);
+  const base::Value::Dict* assignments = state.FindDict(kStateAssignments);
+  if (!assignments) {
+    return std::nullopt;
+  }
+
+  const std::string* folder_id = assignments->FindString(SessionKey(session_id));
+  if (!folder_id || !FolderExists(*folder_id)) {
+    return std::nullopt;
+  }
+  return *folder_id;
+}
+
+std::string ZephyrFolderModel::CreateFolder(const std::u16string& title) {
+  EnsureStateShape();
+
+  std::string folder_id = GenerateFolderId();
+  ScopedDictPrefUpdate update(pref_service_, prefs::kZephyrFoldersState);
+  base::Value::Dict& state = update.Get();
+  base::Value::Dict* folders_dict = state.FindDict(kStateFolders);
+  base::Value::List* order = state.FindList(kStateOrder);
+  CHECK(folders_dict);
+  CHECK(order);
+
+  base::Value::Dict folder;
+  folder.Set(kFolderTitle, base::UTF16ToUTF8(title));
+  folder.Set(kFolderCollapsed, false);
+  folder.Set(kFolderIcon, "folder");
+  folder.Set(kFolderTheme, "default");
+
+  folders_dict->Set(folder_id, std::move(folder));
+  order->Append(folder_id);
+
+  NotifyChanged();
+  return folder_id;
+}
+
+bool ZephyrFolderModel::RenameFolder(const std::string& folder_id,
+                                     const std::u16string& title) {
+  EnsureStateShape();
+  ScopedDictPrefUpdate update(pref_service_, prefs::kZephyrFoldersState);
+  base::Value::Dict* folders = update.Get().FindDict(kStateFolders);
+  if (!folders) {
+    return false;
+  }
+  base::Value::Dict* folder = folders->FindDict(folder_id);
+  if (!folder) {
+    return false;
+  }
+  folder->Set(kFolderTitle, base::UTF16ToUTF8(title));
+  NotifyChanged();
+  return true;
+}
+
+bool ZephyrFolderModel::SetFolderCollapsed(const std::string& folder_id,
+                                           bool collapsed) {
+  EnsureStateShape();
+  ScopedDictPrefUpdate update(pref_service_, prefs::kZephyrFoldersState);
+  base::Value::Dict* folders = update.Get().FindDict(kStateFolders);
+  if (!folders) {
+    return false;
+  }
+  base::Value::Dict* folder = folders->FindDict(folder_id);
+  if (!folder) {
+    return false;
+  }
+  if (folder->FindBool(kFolderCollapsed).value_or(false) == collapsed) {
+    return true;
+  }
+  folder->Set(kFolderCollapsed, collapsed);
+  NotifyChanged();
+  return true;
+}
+
+bool ZephyrFolderModel::AssignSessionToFolder(int32_t session_id,
+                                              const std::string& folder_id) {
+  if (!FolderExists(folder_id)) {
+    return false;
+  }
+
+  EnsureStateShape();
+  ScopedDictPrefUpdate update(pref_service_, prefs::kZephyrFoldersState);
+  base::Value::Dict* assignments = update.Get().FindDict(kStateAssignments);
+  if (!assignments) {
+    return false;
+  }
+  assignments->Set(SessionKey(session_id), folder_id);
+  NotifyChanged();
+  return true;
+}
+
+bool ZephyrFolderModel::UnassignSession(int32_t session_id) {
+  EnsureStateShape();
+  ScopedDictPrefUpdate update(pref_service_, prefs::kZephyrFoldersState);
+  base::Value::Dict* assignments = update.Get().FindDict(kStateAssignments);
+  if (!assignments) {
+    return false;
+  }
+  if (!assignments->Remove(SessionKey(session_id))) {
+    return false;
+  }
+  NotifyChanged();
+  return true;
+}
+
+void ZephyrFolderModel::CleanupAssignments(
+    const std::set<int32_t>& active_session_ids) {
+  EnsureStateShape();
+  ScopedDictPrefUpdate update(pref_service_, prefs::kZephyrFoldersState);
+  base::Value::Dict* assignments = update.Get().FindDict(kStateAssignments);
+  if (!assignments) {
+    return;
+  }
+
+  std::vector<std::string> keys_to_remove;
+  for (const auto [key, value] : *assignments) {
+    int session_id = 0;
+    if (!base::StringToInt(key, &session_id) ||
+        !active_session_ids.contains(session_id) || !value.is_string() ||
+        !FolderExists(*value.GetIfString())) {
+      keys_to_remove.push_back(key);
+    }
+  }
+
+  if (keys_to_remove.empty()) {
+    return;
+  }
+
+  for (const std::string& key : keys_to_remove) {
+    assignments->Remove(key);
+  }
+  NotifyChanged();
+}
+
+void ZephyrFolderModel::MaybeRunNativeGroupMigration(
+    TabStripModel* tab_strip_model) {
+  if (GetSchemaVersion() >= kCurrentSchemaVersion) {
+    return;
+  }
+
+  EnsureStateShape();
+  if (!tab_strip_model || !tab_strip_model->SupportsTabGroups() ||
+      !tab_strip_model->group_model()) {
+    pref_service_->SetInteger(prefs::kZephyrFoldersSchemaVersion,
+                              kCurrentSchemaVersion);
+    return;
+  }
+
+  std::vector<tab_groups::TabGroupId> groups =
+      tab_strip_model->group_model()->ListTabGroups();
+  int fallback_index = 1;
+
+  for (const tab_groups::TabGroupId& group_id : groups) {
+    const TabGroup* group = tab_strip_model->group_model()->GetTabGroup(group_id);
+    if (!group) {
+      continue;
+    }
+
+    std::string folder_id =
+        CreateFolder(GetMigrationTitle(group->visual_data()->title(),
+                                       fallback_index++));
+    SetFolderCollapsed(folder_id, group->visual_data()->is_collapsed());
+
+    std::vector<int> grouped_indices;
+    const gfx::Range range = group->ListTabs();
+    for (int index = range.start(); index < range.end(); ++index) {
+      tabs::TabInterface* tab = tab_strip_model->GetTabAtIndex(index);
+      if (!tab || tab->GetGroup() != group_id) {
+        continue;
+      }
+
+      if (std::optional<int32_t> session_id = GetSessionIdForTab(tab);
+          session_id.has_value()) {
+        AssignSessionToFolder(*session_id, folder_id);
+      }
+      grouped_indices.push_back(index);
+    }
+
+    if (!grouped_indices.empty()) {
+      tab_strip_model->RemoveFromGroup(grouped_indices);
+    }
+  }
+
+  pref_service_->SetInteger(prefs::kZephyrFoldersSchemaVersion,
+                            kCurrentSchemaVersion);
+}
+
+std::string ZephyrFolderModel::GenerateFolderId() {
+  ScopedDictPrefUpdate update(pref_service_, prefs::kZephyrFoldersState);
+  base::Value::Dict& state = update.Get();
+  int next_folder_id = state.FindInt(kStateNextFolderId).value_or(1);
+  state.Set(kStateNextFolderId, next_folder_id + 1);
+  return "folder-" + base::NumberToString(next_folder_id);
+}
+
+bool ZephyrFolderModel::FolderExists(const std::string& folder_id) const {
+  const base::Value::Dict& state =
+      pref_service_->GetDict(prefs::kZephyrFoldersState);
+  const base::Value::Dict* folders = state.FindDict(kStateFolders);
+  return folders && folders->contains(folder_id);
+}
+
+void ZephyrFolderModel::EnsureStateShape() {
+  ScopedDictPrefUpdate update(pref_service_, prefs::kZephyrFoldersState);
+  base::Value::Dict& state = update.Get();
+  if (!state.FindInt(kStateNextFolderId)) {
+    state.Set(kStateNextFolderId, 1);
+  }
+  if (!state.FindDict(kStateFolders)) {
+    state.Set(kStateFolders, base::Value::Dict());
+  }
+  if (!state.FindList(kStateOrder)) {
+    state.Set(kStateOrder, base::Value::List());
+  }
+  if (!state.FindDict(kStateAssignments)) {
+    state.Set(kStateAssignments, base::Value::Dict());
+  }
+}
+
+void ZephyrFolderModel::NotifyChanged() {
+  on_changed_callback_list_.Notify();
+}
+
+std::u16string GetZephyrDefaultFolderTitle(int index) {
+  return u"Folder " + base::NumberToString16(index);
+}
+
+std::optional<int32_t> GetSessionIdForTab(const TabInterface* tab) {
+  if (!tab) {
+    return std::nullopt;
+  }
+  return SessionMappedTabHandleFactory::GetInstance().GetSessionIdForHandle(
+      tab->GetHandle().raw_value());
+}
