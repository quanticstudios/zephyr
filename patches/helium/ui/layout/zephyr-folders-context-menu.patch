@@ -0,0 +1,68 @@
+// Copyright 2026 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/ui/tabs/zephyr_existing_folder_sub_menu_model.h"
+
+#include "chrome/browser/ui/tabs/tab_strip_model.h"
+#include "chrome/browser/ui/tabs/zephyr_folder_menu_commands.h"
+#include "chrome/browser/ui/tabs/zephyr_folder_window_controller.h"
+
+namespace tabs {
+
+ZephyrExistingFolderSubMenuModel::ZephyrExistingFolderSubMenuModel(
+    TabStripModel* tab_strip,
+    int context_index,
+    ZephyrFolderWindowController* folder_controller)
+    : ui::SimpleMenuModel(this),
+      tab_strip_(tab_strip),
+      context_index_(context_index),
+      folder_controller_(folder_controller) {
+  AddItem(kCommandZephyrFolderNewFromSelection, u"New Folder from Selection");
+
+  if (!folder_controller_) {
+    return;
+  }
+
+  AddSeparator(ui::NORMAL_SEPARATOR);
+  int command_id = kMinCommandZephyrFolderExisting;
+  for (const auto& folder : folder_controller_->GetFolders()) {
+    AddItem(command_id, folder.title);
+    command_to_folder_id_[command_id] = folder.id;
+    ++command_id;
+  }
+}
+
+ZephyrExistingFolderSubMenuModel::~ZephyrExistingFolderSubMenuModel() =
+    default;
+
+bool ZephyrExistingFolderSubMenuModel::IsCommandIdEnabled(int command_id) const {
+  if (!folder_controller_ || !tab_strip_) {
+    return false;
+  }
+  if (command_id == kCommandZephyrFolderNewFromSelection) {
+    return tab_strip_->ContainsIndex(context_index_);
+  }
+  return command_to_folder_id_.contains(command_id);
+}
+
+void ZephyrExistingFolderSubMenuModel::ExecuteCommand(int command_id,
+                                                      int event_flags) {
+  if (!folder_controller_) {
+    return;
+  }
+
+  if (command_id == kCommandZephyrFolderNewFromSelection) {
+    folder_controller_->CreateFolderFromSelection(context_index_);
+    return;
+  }
+
+  auto it = command_to_folder_id_.find(command_id);
+  if (it == command_to_folder_id_.end()) {
+    return;
+  }
+
+  folder_controller_->MoveSelectionToFolder(context_index_, it->second);
+}
+
+}  // namespace tabs
