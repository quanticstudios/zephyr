+
+#ifndef CHROME_BROWSER_UI_TABS_ZEPHYR_EXISTING_FOLDER_SUB_MENU_MODEL_H_
+#define CHROME_BROWSER_UI_TABS_ZEPHYR_EXISTING_FOLDER_SUB_MENU_MODEL_H_
+
+#include <map>
+#include <string>
+
+#include "base/memory/raw_ptr.h"
+#include "ui/menus/simple_menu_model.h"
+
+class TabStripModel;
+
+namespace tabs {
+class ZephyrFolderWindowController;
+
+class ZephyrExistingFolderSubMenuModel : public ui::SimpleMenuModel,
+                                         public ui::SimpleMenuModel::Delegate {
+ public:
+  ZephyrExistingFolderSubMenuModel(TabStripModel* tab_strip,
+                                   int context_index,
+                                   ZephyrFolderWindowController* folder_controller);
+  ZephyrExistingFolderSubMenuModel(const ZephyrExistingFolderSubMenuModel&) =
+      delete;
+  ZephyrExistingFolderSubMenuModel& operator=(
+      const ZephyrExistingFolderSubMenuModel&) = delete;
+  ~ZephyrExistingFolderSubMenuModel() override;
+
+  // ui::SimpleMenuModel::Delegate:
+  bool IsCommandIdEnabled(int command_id) const override;
+  void ExecuteCommand(int command_id, int event_flags) override;
+
+ private:
+  const raw_ptr<TabStripModel> tab_strip_;
+  const int context_index_;
+  const raw_ptr<ZephyrFolderWindowController> folder_controller_;
+  std::map<int, std::string> command_to_folder_id_;
+};
+
+}  // namespace tabs
+
+#endif  // CHROME_BROWSER_UI_TABS_ZEPHYR_EXISTING_FOLDER_SUB_MENU_MODEL_H_
