+
+void HeliumLayoutStateController::NormalizeDefaultLayoutIfNeeded() {
+  const PrefService::Preference* pref =
+      pref_service_->FindPreference(prefs::kHeliumLayout);
+  if (!pref || pref->IsManaged() || pref->HasUserSetting()) {
+    return;
+  }
+
+  const int vertical = std::to_underlying(HeliumLayoutType::kVertical);
+  if (pref_service_->GetInteger(prefs::kHeliumLayout) != vertical) {
+    pref_service_->SetInteger(prefs::kHeliumLayout, vertical);
+  }
+}
