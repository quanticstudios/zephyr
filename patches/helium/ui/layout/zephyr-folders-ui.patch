+void VerticalTabGroupView::ShowDropIndicator(DropPosition position) {
+  drop_indicator_above_->SetVisible(position == DropPosition::kAbove);
+  drop_indicator_inside_->SetVisible(position == DropPosition::kInside);
+  drop_indicator_below_->SetVisible(position == DropPosition::kBelow);
+  InvalidateLayout();
+}
+
+void VerticalTabGroupView::HideDropIndicator() {
+  drop_indicator_above_->SetVisible(false);
+  drop_indicator_inside_->SetVisible(false);
+  drop_indicator_below_->SetVisible(false);
+  InvalidateLayout();
+}
